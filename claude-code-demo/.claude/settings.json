{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '. + {event: \"PreToolUse\"}' >> .claude/logs/events.jsonl"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '. + {event: \"PostToolUse\"}' >> .claude/logs/events.jsonl"
          }
        ]
      }
    ],
